# Copy this file to scripts/gcp.env and fill in the values.
# scripts/gcp.env is gitignored — do not commit it once it has real values.

export PROJECT=your-project-id
export REGION=europe-west1
export INSTANCE=highscore-pg
export DB=highscore
# Restricted Postgres role used by the Cloud Run service. NOT the Cloud SQL
# admin (`postgres`); see "Database roles" in README.md for provisioning.
export DB_USER=highscore_server_app
export REPO=highscore
export SERVICE=highscore-server

# App basic-auth username (the password lives in Secret Manager).
export AUTH_USERNAME=admin

# Secret Manager secret names. Override only if they collide with other projects.
export DB_PASSWORD_SECRET=db-password
export AUTH_PASSWORD_SECRET=auth-password

# Optional: pre-set passwords here to skip the interactive prompt in setup.sh.
# Leave blank/commented to be prompted.
# export DB_PASSWORD=
# export AUTH_PASSWORD=
